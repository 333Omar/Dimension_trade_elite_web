<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dimensión Trade</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">

<style>
:root{
--gold:#C9A84C;
--dark:#0D0D0D;
--text:#E8E0D0;
}

/* BASE */
body{
margin:0;
background:var(--dark);
color:var(--text);
font-family:'Source Sans 3',sans-serif;
}

/* LOGIN */
#welcome-layer{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:#000;
z-index:9999;
display:flex;
align-items:center;
justify-content:center;
flex-direction:column;
}

#neural-canvas{
position:absolute;
width:100%;
height:100%;
top:0;
left:0;
z-index:1;
}

.welcome-content{
position:relative;
z-index:10;
text-align:center;
}

.welcome-logo{
width:200px;
height:200px;
border-radius:50%;
border:3px solid var(--gold);
object-fit:cover;
filter:drop-shadow(0 0 20px var(--gold));
animation:pulse 3s infinite;
}

@keyframes pulse{
0%{transform:scale(1);}
50%{transform:scale(1.05);}
100%{transform:scale(1);}
}

.welcome-msg{
font-family:'Playfair Display',serif;
font-size:2.5rem;
color:var(--gold);
margin:20px 0;
}

/* MANUAL */
.hero{
padding:80px 20px;
text-align:center;
border-bottom:1px solid var(--gold);
}

.hero h1{
font-size:3rem;
}

.section{
padding:40px 20px;
}

/* oculto hasta login */
#main-content{
display:none;
}
</style>
</head>

<body>

<!-- LOGIN -->
<div id="welcome-layer">
<canvas id="neural-canvas"></canvas>

<div class="welcome-content">
<img src="unnamed (42).jpg" class="welcome-logo">

<h1 class="welcome-msg">Bienvenido a Dimensión Trade</h1>

<div id="telegram-login-container">
<script async src="https://telegram.org/js/telegram-widget.js?22"
data-telegram-login="DMSTrade_bot"
data-size="large"
data-onauth="onTelegramAuth(user)"
data-request-access="write">
</script>
</div>

</div>
</div>

<!-- CONTENIDO -->
<div id="main-content">

<div class="hero">
<h1>Velas Japonesas & Figuras Chartistas</h1>
<p>Manual completo de análisis técnico</p>
</div>

<div class="section">
<h2>Tu manual sigue exactamente igual acá</h2>
<p>
📌 IMPORTANTE:  
Para no romper tu diseño original (que es largo), pegá TODO tu manual
desde el `<div class="hero">` hacia abajo reemplazando este bloque.
</p>
</div>

</div>

<script>

/* LOGIN TELEGRAM */
function onTelegramAuth(user){
console.log(user);
localStorage.setItem("user", JSON.stringify(user));

document.getElementById("welcome-layer").style.display="none";
document.getElementById("main-content").style.display="block";
}

/* AUTO LOGIN */
window.onload=()=>{
const user=localStorage.getItem("user");
if(user){
document.getElementById("welcome-layer").style.display="none";
document.getElementById("main-content").style.display="block";
}
};

/* RED NEURONAL */
const canvas=document.getElementById("neural-canvas");
const ctx=canvas.getContext("2d");

canvas.width=window.innerWidth;
canvas.height=window.innerHeight;

let particles=[];

for(let i=0;i<80;i++){
particles.push({
x:Math.random()*canvas.width,
y:Math.random()*canvas.height,
vx:(Math.random()-0.5),
vy:(Math.random()-0.5)
});
}

let mouse={x:null,y:null};

window.addEventListener("mousemove",e=>{
mouse.x=e.x;
mouse.y=e.y;
});

function animate(){
ctx.clearRect(0,0,canvas.width,canvas.height);

particles.forEach(p=>{
p.x+=p.vx;
p.y+=p.vy;

if(p.x<0||p.x>canvas.width)p.vx*=-1;
if(p.y<0||p.y>canvas.height)p.vy*=-1;

if(mouse.x){
let dx=mouse.x-p.x;
let dy=mouse.y-p.y;
let dist=Math.sqrt(dx*dx+dy*dy);

if(dist<120){
p.x+=dx*0.01;
p.y+=dy*0.01;
}
}

ctx.beginPath();
ctx.arc(p.x,p.y,2,0,Math.PI*2);
ctx.fillStyle="#C9A84C";
ctx.fill();
});

for(let i=0;i<particles.length;i++){
for(let j=i;j<particles.length;j++){
let dx=particles[i].x-particles[j].x;
let dy=particles[i].y-particles[j].y;
let dist=Math.sqrt(dx*dx+dy*dy);

if(dist<120){
ctx.beginPath();
ctx.strokeStyle="rgba(201,168,76,0.1)";
ctx.moveTo(particles[i].x,particles[i].y);
ctx.lineTo(particles[j].x,particles[j].y);
ctx.stroke();
}
}
}

requestAnimationFrame(animate);
}

animate();

</script>

</body>
</html>
